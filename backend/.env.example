# ── Server ─────────────────────────────────────────────────────────────
PORT=5000
MONGO_URI=mongodb://localhost:27017/creator-analytics

# ── Local DNS Override (optional, localhost only) ─────────────────────
# On Windows, if a stopped VPN / ad-blocker / DoH proxy left the system
# DNS pointing at 127.0.0.1, Node's MongoDB driver fails SRV lookups with
# `ECONNREFUSED querySrv ...` even though `nslookup` works. Set this to a
# comma-separated list of public IPv4 resolvers to route c-ares through them.
# Leave commented on Vercel — the platform's DNS is correctly configured.
# Diagnostic: `npm run db:check`
DNS_RESOLVERS=1.1.1.1,8.8.8.8

# ── YouTube Data API ───────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── AI Provider Configuration ───────────────────────────────────────────
# Set to "deepseek" to use DeepSeek V4 completions, or "stub" for mock responses.
AI_PROVIDER=deepseek

# DeepSeek V4 — deployed on Azure AI Foundry (OpenAI-compatible /openai/v1 endpoint).
# DEEPSEEK_BASE_URL accepts either the base path or the full /chat/completions URL;
# the provider strips a trailing /chat/completions automatically.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://your-resource.services.ai.azure.com/openai/v1
DEEPSEEK_MODEL=DeepSeek-V4-Pro

# Optional transport knobs (sensible defaults if unset)
# DEEPSEEK_TIMEOUT_MS=120000
# DEEPSEEK_MAX_RETRIES=2

# Budget limits (USD) — leave empty or 0 for unlimited
DEEPSEEK_DAILY_BUDGET_USD=5.00
DEEPSEEK_MONTHLY_BUDGET_USD=50.00

# ── Queue / Redis Configuration ───────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
QUEUE_PUBLISH_CONCURRENCY=3
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_BACKOFF_MS=30000

# ── Scheduler Engine Configuration ────────────────────────────────────
# Escalating retry delays in ms (1 min, 5 min, 15 min)
SCHEDULER_RETRY_DELAYS=60000,300000,900000
SCHEDULER_MAX_RETRIES=3

# ── Twitter/X OAuth 2.0 ──────────────────────────────────────────────
# https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here
TWITTER_REDIRECT_URI=http://localhost:5000/api/twitter/auth/callback
TWITTER_SCOPES=tweet.read tweet.write users.read offline.access
FRONTEND_URL=http://localhost:5174

# ── Token Encryption ─────────────────────────────────────────────────
# 32-byte (64-char) hex key used to encrypt stored OAuth tokens at rest.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: rotating this key invalidates all currently-encrypted OAuth tokens —
# connected accounts must be re-authenticated after a rotation.
ENCRYPTION_KEY=generate_a_64_char_hex_key_with_crypto_randomBytes

# ── LinkedIn OAuth 2.0 ───────────────────────────────────────────────
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/linkedin/auth/callback
LINKEDIN_SCOPES=openid profile email w_member_social

# ── Publishing Mode Flag ─────────────────────────────────────────────
PUBLISHING_MODE=live

# ── Instagram Analytics Integration Settings ──────────────────────────
# Active provider: rapidapi (default, username-based onboarding), mock (offline dev).
# Instagram onboarding is username-based — accounts are added by handle, no OAuth.
INSTAGRAM_PROVIDER=rapidapi

# RapidAPI Credentials — required when INSTAGRAM_PROVIDER=rapidapi
# https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=instagram-scrapper-new.p.rapidapi.com

# Caching Layer Durations (in seconds)
CACHE_TTL_PROFILE=3600
CACHE_TTL_REELS=1800
CACHE_TTL_COMMENTS=1800

# ── Search Provider (Research Workspace) ─────────────────────────────────
# Optional. Default is 'stub' (non-grounded — AI-only verification with a
# 'Limited verification' warning surfaced in the UI).
# Set to 'tavily' or 'bing' once the corresponding provider file exists in
# backend/services/search/ and the API key is configured.
# SEARCH_PROVIDER=stub
# TAVILY_API_KEY=
# AZURE_BING_SEARCH_KEY=
