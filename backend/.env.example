# ── Server ─────────────────────────────────────────────────────────────
PORT=5000
MONGO_URI=mongodb://localhost:27017/creator-analytics

# ── YouTube Data API ───────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── AI Provider Configuration ───────────────────────────────────────────
# Set to "openai" to use real GPT completions, or "stub" for mock responses
AI_PROVIDER=openai

# Your OpenAI API key (required when AI_PROVIDER=openai)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Two-model architecture
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-4o

# Budget limits (USD) — leave empty or 0 for unlimited
OPENAI_DAILY_BUDGET_USD=5.00
OPENAI_MONTHLY_BUDGET_USD=50.00

# ── Queue / Redis Configuration ───────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
QUEUE_PUBLISH_CONCURRENCY=3
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_BACKOFF_MS=30000

# ── Scheduler Engine Configuration ────────────────────────────────────
# Escalating retry delays in ms (1 min, 5 min, 15 min)
SCHEDULER_RETRY_DELAYS=60000,300000,900000
SCHEDULER_MAX_RETRIES=3

# ── Twitter/X OAuth 2.0 ──────────────────────────────────────────────
# https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here
TWITTER_REDIRECT_URI=http://localhost:5000/api/twitter/auth/callback
TWITTER_SCOPES=tweet.read tweet.write users.read offline.access
FRONTEND_URL=http://localhost:5174

# ── Token Encryption ─────────────────────────────────────────────────
# 32-byte (64-char) hex key used to encrypt stored OAuth tokens at rest.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: rotating this key invalidates all currently-encrypted OAuth tokens —
# connected accounts must be re-authenticated after a rotation.
ENCRYPTION_KEY=generate_a_64_char_hex_key_with_crypto_randomBytes

# ── LinkedIn OAuth 2.0 ───────────────────────────────────────────────
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/linkedin/auth/callback
LINKEDIN_SCOPES=openid profile email w_member_social

# ── Publishing Mode Flag ─────────────────────────────────────────────
PUBLISHING_MODE=live

# ── Instagram Analytics Integration Settings ──────────────────────────
# Active provider: meta (recommended, uses OAuth + Graph API), rapidapi, mock.
# Use "meta" for real analytics; accounts must be connected via the OAuth flow.
INSTAGRAM_PROVIDER=meta

# ── Instagram / Meta Graph API OAuth ─────────────────────────────────
# Register an app at https://developers.facebook.com/ → My Apps → Add Product:
#   1. Add "Facebook Login" and "Instagram Graph API" products
#   2. Under App Settings → Basic, note the App ID and App Secret
#   3. Configure Valid OAuth Redirect URIs to include the URI below
#   4. The Instagram account must be a Business/Creator account linked to a Facebook Page
INSTAGRAM_CLIENT_ID=your_meta_app_id_here
INSTAGRAM_CLIENT_SECRET=your_meta_app_secret_here
INSTAGRAM_REDIRECT_URI=http://localhost:5000/api/instagram/auth/callback
INSTAGRAM_SCOPES=instagram_basic,instagram_manage_insights,instagram_manage_comments,pages_show_list,pages_read_engagement,business_management
META_GRAPH_API_VERSION=v19.0

# RapidAPI Credentials — optional, only used when INSTAGRAM_PROVIDER=rapidapi
# https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=instagram-scrapper-new.p.rapidapi.com

# Caching Layer Durations (in seconds)
CACHE_TTL_PROFILE=3600
CACHE_TTL_REELS=1800
CACHE_TTL_COMMENTS=1800
