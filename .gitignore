# ── Secrets ────────────────────────────────────────────────────────────
# Never commit real environment files. .env.example is the template.
.env
.env.*
!.env.example
.env.local
.env.*.local

# ── Dependencies ───────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build output ───────────────────────────────────────────────────────
dist/
dist-ssr/
build/
**/dist/
**/build/

# ── Logs ───────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

